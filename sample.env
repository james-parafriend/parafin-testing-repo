# ============================================================
# GrubDash + Parafin Demo — Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
#
#   cp sample.env .env
#
# Each credential set needs a unique variable name.
# The names here must match the clientIdVar / clientSecretVar
# values in credentials.json.
#
# See sample.credentials.json for the profile structure.
# ============================================================

# --- Prod ---
PROD_CLIENT_ID=""
PROD_CLIENT_SECRET=""

# --- Sandbox ---
SANDBOX_CLIENT_ID=""
SANDBOX_CLIENT_SECRET=""

# --- Server ---
# PORT=8080
